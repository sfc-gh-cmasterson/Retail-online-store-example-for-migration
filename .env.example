# Root docker-compose env. Copy to .env. These values feed
# docker-compose.yml ONLY (Postgres, Redis, MeiliSearch, MinIO).
# Backend / storefront app env lives in apps/{backend,storefront}/.env.
#
# All values below are LOCAL DEV ONLY. Replace before any non-dev use.

# ---- Postgres ----
POSTGRES_USER=medusa
POSTGRES_PASSWORD=medusa_dev_password
POSTGRES_DB=medusa

# ---- MeiliSearch ----
# Generate a real key for non-dev use: openssl rand -hex 32
MEILI_MASTER_KEY=meili_dev_master_key

# ---- MinIO (S3-compatible local object store) ----
MINIO_ROOT_USER=medusa
MINIO_ROOT_PASSWORD=medusa_minio_dev_password
