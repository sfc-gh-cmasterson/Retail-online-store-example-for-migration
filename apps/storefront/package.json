{
  "name": "@retail-example/storefront",
  "version": "1.0.3",
  "private": true,
  "description": "Next.js storefront for the retail migration example",
  "keywords": [
    "medusa-storefront"
  ],
  "scripts": {
    "dev": "next dev --turbopack -p 8000",
    "build": "next build",
    "start": "next start -p 8000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "analyze": "ANALYZE=true next build",
    "test:e2e": "playwright test",
    "test:e2e:prod": "echo 'Run after: pnpm build && pnpm start (CSP nonce + strict-dynamic only emitted in production)' && playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:component": "jest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "test:storybook": "test-storybook"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@retail-example/shared-types": "workspace:*",
    "@medusajs/icons": "2.15.2",
    "@medusajs/js-sdk": "2.15.2",
    "@medusajs/ui-preset": "2.15.2",
    "@radix-ui/react-accordion": "^1.2.3",
    "@sentry/nextjs": "^8.55.0",
    "@tanstack/react-query": "5.64.2",
    "clsx": "^2.1.1",
    "lodash": "^4.17.21",
    "next": "15.5.18",
    "qs": "^6.12.1",
    "react": "19.0.5",
    "react-country-flag": "^3.1.0",
    "react-dom": "19.0.5",
    "server-only": "^0.0.1",
    "sonner": "^1.7.4",
    "tailwindcss-radix": "^2.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.17.5",
    "@medusajs/types": "2.15.2",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^8.4.0",
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/addon-interactions": "^8.4.0",
    "@storybook/addon-themes": "^8.4.0",
    "@storybook/blocks": "^8.4.0",
    "@storybook/nextjs": "^8.4.0",
    "@storybook/react": "^8.4.0",
    "@storybook/test": "^8.4.0",
    "@storybook/test-runner": "^0.19.0",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/google.maps": "^3.64.1",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.14.195",
    "@types/node": "17.0.21",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/react-instantsearch-dom": "^6.12.3",
    "ansi-colors": "^4.1.3",
    "autoprefixer": "^10.4.2",
    "babel-loader": "^8.2.3",
    "eslint": "^9.13.0",
    "eslint-config-next": "15.5.18",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.8",
    "prettier": "^2.8.8",
    "storybook": "^8.4.0",
    "tailwindcss": "^3.0.23",
    "typescript": "^5.3.2"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.20.2",
    "pnpm": ">=10.33.2"
