# Next.js storefront env. Copy to apps/storefront/.env.local (or .env)
# and adjust per environment.
#
# Anything prefixed NEXT_PUBLIC_ is bundled into the browser at build time
# — never put secrets there. NODE_ENV is set by Next; do not override.

# ============================================================================
# Backend connection
# ============================================================================
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
# prod: https://api.example.com

# Publishable key from Medusa admin (Settings -> API Key Management).
# Storefront reads this key for every /store/* call.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# ============================================================================
# Site identity / SEO
# ============================================================================
NEXT_PUBLIC_BASE_URL=http://localhost:8000
NEXT_PUBLIC_STORE_URL=http://localhost:8000
# prod:
#   NEXT_PUBLIC_BASE_URL=https://example.com
#   NEXT_PUBLIC_STORE_URL=https://example.com

# Comma-separated list of hostnames that next/image is allowed to load
# from. Read by next.config.js. Include your CDN, S3 bucket, MinIO host,
# and any third-party image source.
STOREFRONT_IMAGE_HOSTS=localhost
# prod example:
#   STOREFRONT_IMAGE_HOSTS=cdn.example.com,assets.example.com,*.r2.cloudflarestorage.com

# ============================================================================
# Payment display
# ============================================================================
NEXT_PUBLIC_PAYID_ALIAS=payments@example.test

# ============================================================================
# Optional integrations — leave empty to disable
# ============================================================================

# Sentry browser SDK
NEXT_PUBLIC_SENTRY_DSN=

# Plausible analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SRC=

# Google Maps (address autocomplete)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
