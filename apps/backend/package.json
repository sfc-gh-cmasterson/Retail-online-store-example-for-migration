{
  "name": "@retail-example/backend",
  "version": "0.0.1",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build",
    "start": "medusa start",
    "dev": "medusa develop",
    "typecheck": "tsc --noEmit",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit --passWithNoTests",
    "shipengine:list-carriers": "medusa exec ./src/scripts/shipengine-list-carriers.ts"
  },
  "dependencies": {
    "@retail-example/shared-types": "workspace:*",
    "@medusajs/admin-sdk": "2.15.2",
    "@medusajs/admin-shared": "2.15.2",
    "@medusajs/caching": "2.15.2",
    "@medusajs/cli": "2.15.2",
    "@medusajs/dashboard": "2.15.2",
    "@medusajs/draft-order": "2.15.2",
    "@medusajs/file-s3": "^2.15.2",
    "@medusajs/framework": "2.15.2",
    "@medusajs/js-sdk": "2.15.2",
    "@medusajs/medusa": "2.15.2",
    "@medusajs/ui": "4.1.12",
    "@react-email/components": "^0.0.30",
    "@react-email/render": "^1.4.0",
    "@sentry/node": "^8.55.0",
    "@tanstack/react-query": "5.64.2",
    "ioredis": "^5.10.1",
    "meilisearch": "^0.58.0",
    "pg": "^8.20.0",
    "rate-limiter-flexible": "^11.1.0",
    "react-i18next": "13.5.0",
    "react-router-dom": "6.30.3",
    "resend": "^6.12.2",
    "zod": "4.2.0"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.15.2",
    "@swc/core": "^1.5",
    "@swc/jest": "^0.2",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.12.11",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.14",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20.20.2",
    "pnpm": ">=10.33.2"
  },
  "packageManager": "pnpm@10.33.2"
}