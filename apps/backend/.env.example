# Medusa backend env. Copy to apps/backend/.env (or symlink from repo root)
# and adjust per environment.
#
# Defaults here target the local docker-compose stack. For staging/production
# replace each section with managed-service values; the inline `# prod:`
# comments show typical replacements.
#
# Generate every secret with:  openssl rand -hex 32

# ============================================================================
# Database / cache / search
# ============================================================================
DATABASE_URL=postgres://medusa:medusa_dev_password@localhost:5432/medusa
# prod: postgres://USER:PASSWORD@HOST:5432/medusa?sslmode=require   (Neon, RDS, Supabase, etc.)

REDIS_URL=redis://localhost:6379
# prod: rediss://default:PASSWORD@HOST:6379                          (Upstash, ElastiCache, etc.)

MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=meili_dev_master_key
MEDUSA_FF_INDEX_ENGINE=true
# prod MEILI_HOST: https://ms-xxxxx.meilisearch.io                  (MeiliSearch Cloud)

# ============================================================================
# Auth / secrets
# ============================================================================
JWT_SECRET=replace-me-with-openssl-rand-hex-32
COOKIE_SECRET=replace-me-with-openssl-rand-hex-32

# ============================================================================
# Server / admin
# ============================================================================
MEDUSA_WORKER_MODE=shared
# prod: split into separate `server` and `worker` containers, each pinning
#       MEDUSA_WORKER_MODE accordingly.

DISABLE_MEDUSA_ADMIN=false
MEDUSA_ADMIN_PATH=/admin
# Set to /troon/admin (or any opaque path) to make the admin URL non-obvious.

MEDUSA_BACKEND_URL=http://localhost:9000
# prod: https://api.example.com

# ============================================================================
# CORS — comma-separated origins
# ============================================================================
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:8000,http://localhost:9000
# prod:
#   STORE_CORS=https://example.com,https://www.example.com
#   ADMIN_CORS=https://api.example.com
#   AUTH_CORS=https://example.com,https://api.example.com

# ============================================================================
# Storage — generic S3-compatible
# ============================================================================
# Default points at the local MinIO container in docker-compose.yml.
# Adopters can swap in any S3-compatible provider: AWS S3, Cloudflare R2,
# Backblaze B2, Wasabi, Scaleway, Tigris, etc.
S3_ENDPOINT=http://localhost:9100
S3_FILE_URL=http://localhost:9100/medusa
S3_REGION=us-east-1
S3_BUCKET=medusa
S3_ACCESS_KEY=medusa
S3_SECRET_KEY=medusa_dev_password
# prod examples:
#   AWS S3:           S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
#   Cloudflare R2:    S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com  S3_REGION=auto
#   Backblaze B2:     S3_ENDPOINT=https://s3.us-west-002.backblazeb2.com

# ============================================================================
# Email (Resend)
# ============================================================================
# Leave empty in dev — emails are logged instead of sent.
RESEND_API_KEY=
RESEND_FROM=orders@example.test
# prod: RESEND_FROM=orders@example.com (must be a verified sender domain)

# ============================================================================
# Observability (Sentry) — optional
# ============================================================================
SENTRY_DSN=

# ============================================================================
# Catalog intelligence (OpenAI) — optional
# ============================================================================
OPENAI_API_KEY=

# ============================================================================
# Payment provider — PayID example (replace with Stripe/PayPal/etc.)
# ============================================================================
PAYID_ALIAS=payments@example.test
PAYID_HOLD_HOURS=72

# ============================================================================
# Shipping providers — optional. Leave empty if not used.
# ============================================================================
# ShipEngine:
SHIPENGINE_API_KEY=
SHIPENGINE_API_BASE=https://api.shipengine.com
SHIPENGINE_CARRIER_IDS=

# Australia Post (PAC):
AUSPOST_API_KEY=
AUSPOST_API_BASE=https://digitalapi.auspost.com.au

# ============================================================================
# Seed configuration (consumed by src/scripts/seed.ts)
# ============================================================================
BRAND_NAME=Retail Example
DEFAULT_CURRENCY=usd
DEFAULT_COUNTRY=us
# DEFAULT_REGION_NAME=United States
# SEED_TEST_ACCOUNTS=true   # creates approved/vip/pending example users
